<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <parent>
        <artifactId>swiftcv-parent</artifactId>
        <groupId>com.gs.swiftcv</groupId>
        <version>1.0.0-SNAPSHOT</version>
    </parent>
    <modelVersion>4.0.0</modelVersion>

    <artifactId>swiftcv-service</artifactId>
    <name>swiftcv-service</name>
    <description>快速生成简历系统 - 业务模块</description>

    <dependencies>
        <!-- Repository Module -->
        <dependency>
            <groupId>com.gs.swiftcv</groupId>
            <artifactId>swiftcv-repository</artifactId>
            <version>1.0.0-SNAPSHOT</version>
        </dependency>

        <!-- Core Module -->
        <dependency>
            <groupId>com.gs.swiftcv</groupId>
            <artifactId>swiftcv-core</artifactId>
            <version>1.0.0-SNAPSHOT</version>
        </dependency>

        <!-- Spring Boot Starter -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter</artifactId>
        </dependency>

        <!-- JSON -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-databind</artifactId>
        </dependency>

        <!-- Lombok -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>
    </dependencies>

</project>
