<view class="container data-v-9d55896e"><block wx:if="{{loading}}"><view class="card muted data-v-9d55896e">加载中...</view></block><block wx:else><block wx:if="{{!detail}}"><view class="card muted data-v-9d55896e">菜谱不存在或已被删除</view></block><block wx:else><view class="card data-v-9d55896e"><text class="title data-v-9d55896e">{{detail.title}}</text><text class="meta data-v-9d55896e">{{"分类："+(detail.categoryName||'未分类')+" · 难度："+(detail.difficulty||'简单')}}</text><text class="meta data-v-9d55896e">{{'准备 '+(detail.prepTime||0)+" 分钟 · 烹饪 "+(detail.cookTime||0)+" 分钟 · 总用时 "+(detail.totalTime||0)+' 分钟'}}</text><text class="meta data-v-9d55896e">{{"份量："+(detail.servings||'-')+" 人 · 热量："+(detail.calories||'-')+" kcal"}}</text><text class="desc data-v-9d55896e">{{detail.description||'暂无介绍'}}</text></view><view class="card data-v-9d55896e"><text class="section-title data-v-9d55896e">食材清单</text><block wx:if="{{$root.g0}}"><view class="muted data-v-9d55896e">暂无食材信息</view></block><block wx:for="{{detail.ingredients}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view class="ingredient-row data-v-9d55896e"><text class="ingredient-name data-v-9d55896e">{{item.ingredientName||'未命名食材'}}</text><text class="ingredient-qty data-v-9d55896e">{{item.quantity||'适量'}}</text></view></block></view><view class="card data-v-9d55896e"><text class="section-title data-v-9d55896e">烹饪步骤</text><block wx:if="{{$root.g1}}"><view class="muted data-v-9d55896e">暂无步骤信息</view></block><block wx:for="{{detail.steps}}" wx:for-item="step" wx:for-index="index" wx:key="index"><view class="step-item data-v-9d55896e"><text class="step-title data-v-9d55896e">{{"步骤 "+(step.stepNumber||index+1)}}</text><text class="step-desc data-v-9d55896e">{{step.description||'暂无描述'}}</text><block wx:if="{{step.tips}}"><text class="step-tip data-v-9d55896e">{{"小贴士："+step.tips}}</text></block></view></block></view><block wx:if="{{detail.tips}}"><view class="card tips-card data-v-9d55896e"><text class="section-title data-v-9d55896e">整体贴士</text><text class="desc data-v-9d55896e">{{detail.tips}}</text></view></block></block></block></view>